rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bewerbungen: jeder darf schreiben, nur eingeloggter Admin darf lesen
    match /bewerbungen/{id} {
      allow write: if true;
      allow read:  if request.auth != null;
    }

    // FCM-Tokens: nur eingeloggter Admin
    match /fcmTokens/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
